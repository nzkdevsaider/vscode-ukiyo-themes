  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7a6e68", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "punctuation.definition.string", "string.template"],
      "settings": { "foreground": "#e8a87c" }
    },
    {
      "name": "Template literal expression",
      "scope": ["string.template punctuation.definition.template-expression"],
      "settings": { "foreground": "#c9a0dc" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.in"
      ],
      "settings": { "foreground": "#7ec8e3" }
    },
    {
      "name": "Storage / Modifiers",
      "scope": [
        "storage.type",
        "storage.modifier",
        "keyword.declaration",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#7ec8e3", "fontStyle": "italic" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": { "foreground": "#f0c060" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#e8a87c", "fontStyle": "italic" }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#82cfaa" }
    },
    {
      "name": "Type annotation",
      "scope": [
        "meta.type.annotation",
        "meta.type.parameters",
        "support.type.primitive",
        "storage.type.generic"
      ],
      "settings": { "foreground": "#82cfaa", "fontStyle": "italic" }
    },
    {
      "name": "Interfaces (TypeScript)",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#82cfaa", "fontStyle": "italic" }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": { "foreground": "#c9a0dc" }
    },
    {
      "name": "Booleans & null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": { "foreground": "#c9a0dc", "fontStyle": "italic" }
    },
    {
      "name": "Constants",
      "scope": ["constant.language", "variable.other.constant"],
      "settings": { "foreground": "#c9a0dc" }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#f0c060" }
    },
    {
      "name": "Object keys — strings",
      "scope": ["meta.object-literal.key string"],
      "settings": { "foreground": "#f0c060" }
    },
    {
      "name": "Variable declarations",
      "scope": ["variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#ede0cf" }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag", "meta.tag.structure entity.name.tag"],
      "settings": { "foreground": "#f08080" }
    },
    {
      "name": "HTML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#f0c060" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css", "entity.name.tag.css"],
      "settings": { "foreground": "#7ec8e3" }
    },
    {
      "name": "CSS Values",
      "scope": ["support.constant.property-value.css", "constant.other.color"],
      "settings": { "foreground": "#e8a87c" }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#82cfaa" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "keyword.operator.arithmetic"],
      "settings": { "foreground": "#b09a90" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace"
      ],
      "settings": { "foreground": "#b09a90" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": { "foreground": "#c9a0dc", "fontStyle": "italic" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#f0c060", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#ede0cf", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#ede0cf", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": { "foreground": "#82cfaa" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#7ec8e3" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#8a7b70", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list bullet",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#f0c060" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp", "constant.regexp"],
      "settings": { "foreground": "#5fd7c0" }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#c9a0dc" }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module"
      ],
      "settings": { "foreground": "#82cfaa", "fontStyle": "italic" }
    },
    {
      "name": "Enum members",
      "scope": ["variable.other.enummember", "constant.other.enum"],
      "settings": { "foreground": "#c9a0dc" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#f08080", "fontStyle": "underline" }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#c9a0dc", "fontStyle": "italic" }
    },
    {
      "name": "Class method names",
      "scope": ["entity.name.function.method", "meta.method entity.name.function"],
      "settings": { "foreground": "#f0c060" }
    },
    {
      "name": "Arrow function operator",
      "scope": ["storage.type.function.arrow", "keyword.operator.arrow"],
      "settings": { "foreground": "#7ec8e3" }
    },
    {
      "name": "HTML/JSX tag punctuation",
      "scope": ["punctuation.definition.tag", "punctuation.definition.tag.begin", "punctuation.definition.tag.end"],
      "settings": { "foreground": "#6b5e56" }
    },
    {
      "name": "Support constants (Math.PI, etc.)",
      "scope": ["support.constant", "support.constant.math", "support.constant.dom"],
      "settings": { "foreground": "#c9a0dc" }
    },
    {
      "name": "Support variables (console, window, document)",
      "scope": ["support.variable", "support.variable.dom", "support.class.dom"],
      "settings": { "foreground": "#7ec8e3" }
    },
    {
      "name": "Markdown fenced code block",
      "scope": ["markup.fenced_code.block", "markup.raw.block"],
      "settings": { "foreground": "#82cfaa" }
    },
    {
      "name": "JSX/TSX component names",
      "scope": ["support.class.component", "entity.name.tag.tsx", "entity.name.tag.jsx"],
      "settings": { "foreground": "#82cfaa" }
    }
  ]
}
