{
  "name": "Golden Book Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#f1ddcd",
    "editor.foreground": "#460c0c",
    "editorLineNumber.foreground": "#982222",
    "editorLineNumber.activeForeground": "#a72a2a",
    "editorCursor.foreground": "#db791e",
    "editor.selectionBackground": "#e8a46474",
    "editor.inactiveSelectionBackground": "#e8a46444",
    "editor.lineHighlightBackground": "#ead2be",

    "sideBar.background": "#554441",
    "sideBar.foreground": "#f7e8cf",
    "activityBar.background": "#64514d",
    "activityBar.foreground": "#f7e8cf",
    "statusBar.background": "#64514d",
    "statusBar.foreground": "#f7e8cf",

    "panel.background": "#554441",
    "titleBar.activeBackground": "#554441",
    "titleBar.activeForeground": "#f7e8cf",

    "focusBorder": "#ce7726",
    "button.background": "#ce7726",
    "button.foreground": "#f1ddcd",
    "button.hoverBackground": "#db791e",
    "textLink.foreground": "#ce7726",
    "textLink.activeForeground": "#db791e"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#982222", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#db791e" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#ce7726" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#db791e" }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class"],
      "settings": { "foreground": "#962a2a" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#a72a2a" }
    }
  ]
}
