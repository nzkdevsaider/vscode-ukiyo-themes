{
  "name": "Ukiyo Light",
  "type": "light",
  "colors": {
    "editor.background": "#e6f0ff",
    "editor.foreground": "#254da1",
    "editorLineNumber.foreground": "#4069bf",
    "editorLineNumber.activeForeground": "#5079d1",
    "editorCursor.foreground": "#30b4d4",
    "editor.selectionBackground": "#bdd8ff7d",
    "editor.inactiveSelectionBackground": "#bdd8ff44",
    "editor.lineHighlightBackground": "#d0e3ff68",

    "sideBar.background": "#c9d9f1",
    "sideBar.foreground": "#254da1",
    "activityBar.background": "#e1edff",
    "activityBar.foreground": "#254da1",
    "statusBar.background": "#e1edff",
    "statusBar.foreground": "#254da1",

    "panel.background": "#c9d9f1",
    "titleBar.activeBackground": "#c9d9f1",
    "titleBar.activeForeground": "#254da1",

    "focusBorder": "#2b9cb8",
    "button.background": "#2b9cb8",
    "button.foreground": "#e6f0ff",
    "button.hoverBackground": "#30b4d4",
    "textLink.foreground": "#2b9cb8",
    "textLink.activeForeground": "#30b4d4"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#4069bf", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#30b4d4" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#2b9cb8" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#30b4d4" }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class"],
      "settings": { "foreground": "#e67979" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#379eda" }
    }
  ]
}
