{
  "name": "Alchemy Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#171717",
    "editor.foreground": "#c0bcb5",
    "editorLineNumber.foreground": "#8c7c6d",
    "editorLineNumber.activeForeground": "#9e9184",
    "editorCursor.foreground": "#b1996c",
    "editor.selectionBackground": "#474747a2",
    "editor.inactiveSelectionBackground": "#47474755",
    "editor.lineHighlightBackground": "#242424bf",

    "sideBar.background": "#292929",
    "sideBar.foreground": "#c0bcb5",
    "activityBar.background": "#1a1a1a",
    "activityBar.foreground": "#c0bcb5",
    "statusBar.background": "#1a1a1a",
    "statusBar.foreground": "#c0bcb5",

    "panel.background": "#292929",
    "titleBar.activeBackground": "#292929",
    "titleBar.activeForeground": "#c0bcb5",

    "focusBorder": "#978159",
    "button.background": "#978159",
    "button.foreground": "#171717",
    "button.hoverBackground": "#b1996c",
    "textLink.foreground": "#978159",
    "textLink.activeForeground": "#b1996c"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8c7c6d", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#b1996c" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#978159" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#b1996c" }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class"],
      "settings": { "foreground": "#8f2d2d" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#a07f6c" }
    }
  ]
}
