{
  "name": "Golden Coffee Light",
  "type": "light",
  "colors": {
    "editor.background": "#fff3e7",
    "editor.foreground": "#97653c",
    "editorLineNumber.foreground": "#c37e30",
    "editorLineNumber.activeForeground": "#cf8a3a",
    "editorCursor.foreground": "#ec5555",
    "editor.selectionBackground": "#efddcacb",
    "editor.inactiveSelectionBackground": "#efddca88",
    "editor.lineHighlightBackground": "#ffe2c4d1",

    "sideBar.background": "#e0c1a0",
    "sideBar.foreground": "#97653c",
    "activityBar.background": "#fae7d2",
    "activityBar.foreground": "#97653c",
    "statusBar.background": "#fae7d2",
    "statusBar.foreground": "#97653c",

    "panel.background": "#e0c1a0",
    "titleBar.activeBackground": "#e0c1a0",
    "titleBar.activeForeground": "#97653c",

    "focusBorder": "#d83939",
    "button.background": "#d83939",
    "button.foreground": "#fff3e7",
    "button.hoverBackground": "#ec5555",
    "textLink.foreground": "#d83939",
    "textLink.activeForeground": "#ec5555"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#c37e30", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#ec5555" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#d83939" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#ec5555" }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class"],
      "settings": { "foreground": "#da7b64" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#d88405" }
    }
  ]
}
