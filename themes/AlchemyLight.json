{
  "name": "Alchemy Light",
  "type": "dark",
  "colors": {
    "editor.background": "#0f1d1a",
    "editor.foreground": "#cabbab",
    "editorLineNumber.foreground": "#a08d57",
    "editorLineNumber.activeForeground": "#ad9962",
    "editorCursor.foreground": "#c9ab73",
    "editor.selectionBackground": "#334b45b5",
    "editor.inactiveSelectionBackground": "#334b4577",
    "editor.lineHighlightBackground": "#22373270",

    "sideBar.background": "#253a35",
    "sideBar.foreground": "#cabbab",
    "activityBar.background": "#10201d",
    "activityBar.foreground": "#cabbab",
    "statusBar.background": "#10201d",
    "statusBar.foreground": "#cabbab",

    "panel.background": "#253a35",
    "titleBar.activeBackground": "#253a35",
    "titleBar.activeForeground": "#cabbab",

    "focusBorder": "#b49967",
    "button.background": "#b49967",
    "button.foreground": "#0f1d1a",
    "button.hoverBackground": "#c9ab73",
    "textLink.foreground": "#b49967",
    "textLink.activeForeground": "#c9ab73"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#a08d57", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#c9ab73" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#b49967" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#c9ab73" }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class"],
      "settings": { "foreground": "#a83d3d" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#1cacb4" }
    }
  ]
}
