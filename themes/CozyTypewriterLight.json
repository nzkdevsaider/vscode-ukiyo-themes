{
  "name": "Ukiyo - Cozy Typewriter (Light)",
  "type": "light",
  "colors": {
    "editor.background": "#e1c4a6",
    "editor.foreground": "#5f4f49",
    "editorLineNumber.foreground": "#7a6d68",
    "editorLineNumber.activeForeground": "#5b4f4a",
    "editorCursor.foreground": "#a00000",
    "editor.selectionBackground": "#c7a78683",
    "editor.inactiveSelectionBackground": "#c7a78644",
    "editor.lineHighlightBackground": "#d4b4946a",

    "sideBar.background": "#cbaa87",
    "sideBar.foreground": "#5f4f49",
    "activityBar.background": "#daba97",
    "activityBar.foreground": "#5f4f49",
    "statusBar.background": "#daba97",
    "statusBar.foreground": "#5f4f49",

    "panel.background": "#cbaa87",
    "titleBar.activeBackground": "#cbaa87",
    "titleBar.activeForeground": "#5f4f49",

    "focusBorder": "#800000",
    "button.background": "#800000",
    "button.foreground": "#e1c4a6",
    "button.hoverBackground": "#a00000",
    "textLink.foreground": "#800000",
    "textLink.activeForeground": "#a00000"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7a6d68", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#a00000" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#800000" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#a00000" }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class"],
      "settings": { "foreground": "#d34747" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#ae612b" }
    }
  ]
}