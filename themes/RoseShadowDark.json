{
  "name": "Rose Shadow Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#3b252d",
    "editor.foreground": "#d3a590",
    "editorLineNumber.foreground": "#b3826a",
    "editorLineNumber.activeForeground": "#c2937b",
    "editorCursor.foreground": "#c693d1",
    "editor.selectionBackground": "#6e425296",
    "editor.inactiveSelectionBackground": "#6e425255",
    "editor.lineHighlightBackground": "#4e2d3896",

    "sideBar.background": "#773d47",
    "sideBar.foreground": "#d3a590",
    "activityBar.background": "#412730",
    "activityBar.foreground": "#d3a590",
    "statusBar.background": "#412730",
    "statusBar.foreground": "#d3a590",

    "panel.background": "#773d47",
    "titleBar.activeBackground": "#773d47",
    "titleBar.activeForeground": "#d3a590",

    "focusBorder": "#b884c4",
    "button.background": "#b884c4",
    "button.foreground": "#3b252d",
    "button.hoverBackground": "#c693d1",
    "textLink.foreground": "#b884c4",
    "textLink.activeForeground": "#c693d1"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#b3826a", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#c693d1" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#b884c4" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#c693d1" }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class"],
      "settings": { "foreground": "#d12e6d" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#eccfe8" }
    }
  ]
}
